rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in
           get(/databases/$(database)/documents/adminList/config).data.emails;
    }

    function hasPerm(p) {
      return isSignedIn()
        && 'permissions' in request.auth.token
        && (p in request.auth.token.permissions);
    }

    function isMerchantOf(storeId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/approvedApplications/$(storeId)).data.ownerUid
           == request.auth.uid;
    }

    function affects(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth.uid == uid
        && request.resource.data.roleType == 2
        && request.resource.data.permissions.size() == 0
        && !('merchantStoreId' in request.resource.data);
      allow update: if request.auth.uid == uid
        && affects(['fcmToken', 'displayName', 'photoUrl', 'updatedAt']);
      allow update: if isAdmin();
    }

    match /approvedApplications/{storeId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if resource.data.ownerUid == request.auth.uid
        && affects(['showcaseModules', 'description', 'images',
                    'openTime', 'closeTime', 'updatedAt']);
      allow update: if isSignedIn()
        && affects(['viewCount'])
        && request.resource.data.viewCount == resource.data.viewCount + 1;

      match /votes/{voterUid} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
          && voterUid == request.auth.uid
          && request.resource.data.voterUid == request.auth.uid
          && request.resource.data.score is int
          && request.resource.data.score >= 1
          && request.resource.data.score <= 5;
        allow delete: if request.auth.uid == voterUid || isAdmin();
      }
    }

    match /merchantApplications/{uid} {
      allow read: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      allow create: if request.auth.uid == uid
        && request.resource.data.status == 'pending'
        && get(/databases/$(database)/documents/users/$(uid)).data.merchantStoreId == null;
      allow update, delete: if isAdmin();
    }

    match /topics/{topicId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || hasPerm(2);
      allow update, delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid;
        allow delete: if resource.data.authorUid == request.auth.uid || isAdmin();
        allow update: if false;
      }
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if hasPerm(1)
        && request.resource.data.creatorUid == request.auth.uid;
      allow update: if isAdmin()
        || (resource.data.creatorUid == request.auth.uid
            && affects(['name', 'description', 'imageUrl', 'isClosed', 'updatedAt']));
      allow delete: if isAdmin();

      match /members/{memberUid} {
        allow read: if isSignedIn();
        allow create: if request.auth.uid == memberUid;
        allow delete: if request.auth.uid == memberUid
          || get(/databases/$(database)/documents/groups/$(groupId)).data.creatorUid
             == request.auth.uid
          || isAdmin();
      }

      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
          && request.resource.data.authorUid == request.auth.uid;
        allow delete: if resource.data.authorUid == request.auth.uid
          || get(/databases/$(database)/documents/groups/$(groupId)).data.creatorUid
             == request.auth.uid
          || isAdmin();
        allow update: if false;
      }
    }

    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow create: if isMerchantOf(request.resource.data.storeId)
        && request.resource.data.merchantUid == request.auth.uid
        && request.resource.data.ratio is int
        && request.resource.data.ratio >= 1
        && request.resource.data.ratio <= 100
        && request.resource.data.expiresAt is timestamp;
      allow update, delete: if resource.data.merchantUid == request.auth.uid || isAdmin();

      match /redemptions/{rid} {
        allow read: if resource.data.merchantUid == request.auth.uid
          || resource.data.userUid == request.auth.uid
          || isAdmin();
        allow write: if false;
      }
    }

    match /regionalCities/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /regionalTowns/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /towns/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /adminList/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /allowedAdminClaims/{document} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /specialAgency/{agency} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /unApprovedApplications/{appId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /notifications/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /developers/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /logs/{document} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    // CollectionPaths.error — written by FirebaseLogger (e.g. push notification
    // failures). Any signed-in user may append; only admins read/mutate.
    // Without this match, writes were denied by default in production.
    match /error/{document} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /approvedCampaigns/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /unApprovedCampaigns/{document} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /categories/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /unApprovedAdvertise/{document} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /approvedAdvertise/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /news/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /adBoard/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /scholarship/{scholarship} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /chainStores/{chainStore} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /touristicPlaces/{touristicPlace} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /usefulLinks/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
